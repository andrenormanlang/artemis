# Copie para terraform.tfvars e preencha. NÃO faça commit de terraform.tfvars.
aws_region         = "us-east-1"
project            = "artemis"
image_tag          = "latest"

delivery_time_zone = "Europe/Stockholm"
schedule_expression = "cron(0 9 * * ? *)" # diariamente às 09:00 (no fuso acima)

mail_from = "boletim@seudominio.com" # precisa estar verificado no SES
app_host  = "artemis.seudominio.com"

# Rede
vpc_id           = "vpc-xxxxxxxx"
subnet_ids       = ["subnet-aaaa", "subnet-bbbb"]
assign_public_ip = true

# Segredos no Secrets Manager (env var => nome do segredo)
