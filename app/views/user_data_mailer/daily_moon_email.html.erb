<% stockholm_time = Time.find_zone!("Europe/Stockholm").now %>
<% report_date = stockholm_time.strftime("%d/%m/%Y") %>
<% user_name = @user.name.presence || "explorador lunar" %>
<% phase_name = @moon_data.phase.presence || "Sem fase definida" %>
<% sign_name = @moon_data.sign.presence || "Sem signo definido" %>
<% special_name = @moon_data.special_moon.presence || "Nenhuma lua especial" %>
<% full_days = [(@moon_data.days_until_full_moon || 0).to_i, 0].max %>
<% new_days = [(@moon_data.days_until_new_moon || 0).to_i, 0].max %>
<% full_progress = [[100 - (full_days.fdiv(29.53) * 100).round, 100].min, 0].max %>
<% new_progress = [[100 - (new_days.fdiv(29.53) * 100).round, 100].min, 0].max %>
<% next_event_name, next_event_days = full_days <= new_days ? ["Lua cheia", full_days] : ["Lua nova", new_days] %>
<% next_event_copy = case next_event_days
                    when 0
                      "#{next_event_name} hoje"
                    when 1
                      "#{next_event_name} amanhã"
                    else
                      "#{next_event_days} dias para a #{next_event_name.downcase}"
                    end %>
<% hero_copy = case next_event_days
               when 0
                 "A lua está em #{phase_name} e #{next_event_name.downcase} acontece hoje."
               when 1
                 "A lua está em #{phase_name} e #{next_event_name.downcase} chega amanhã."
               else
                 "A lua está em #{phase_name} e faltam #{next_event_days} dias para a #{next_event_name.downcase}."
               end %>
<% insight_title, insight_copy = case phase_name.downcase
                                 when /nova/
                                   ["Momento de recomeço", "Fase boa para plantar intenções, simplificar a agenda e abrir espaço para um novo ciclo."]
                                 when /cheia/
                                   ["Energia no auge", "Período favorável para celebrar progresso, concluir pendências e observar o que ficou mais visível."]
                                 when /minguante/
                                   ["Hora de desacelerar", "A maré pede revisão, fechamento e menos ruído. Um bom momento para ajustar o ritmo."]
                                 when /crescente/
                                   ["Fase de construção", "Clima ideal para ganhar consistência, retomar planos e sustentar o que já começou."]
                                 else
                                   ["Leitura lunar do dia", "Hoje vale observar o céu com calma e usar o boletim como bússola para o ritmo do seu dia."]
                                 end %>
<% phase_icon = case phase_name.downcase
                when /nova/
                  "🌑"
                when /cheia/
                  "🌕"
                when /minguante/
                  "🌗"
                when /crescente/
                  "🌓"
                else
                  "🌙"
                end %>
<% special_pill_class = special_name == "Nenhuma lua especial" ? "pill-neutral" : "pill-special" %>
<% app_host = ENV["APP_HOST"].to_s.strip %>
<% app_url = if app_host.present?
               normalized_host = app_host.match?(/\Ahttps?:\/\//i) ? app_host : "https://#{app_host}"
               "#{normalized_host.chomp("/")}/moon"
             end %>

<div style="display:none; max-height:0; overflow:hidden; mso-hide:all; font-size:1px; line-height:1px; color:#07111f;">
  <%= "#{phase_name} hoje. #{next_event_copy.capitalize} e leitura rápida do seu ciclo lunar." %>
</div>

<table role="presentation" width="100%" class="email-body">
  <tr>
    <td align="center" style="padding: 24px 12px;">
      <table role="presentation" width="100%" class="shell">
        <tr>
          <td>
            <table role="presentation" width="100%" class="card">
              <tr>
                <td class="hero">
                  <table role="presentation" width="100%" class="mobile-block">
                    <tr>
                      <td style="vertical-align: top;">
                        <p class="eyebrow">Boletim Lunar • <%= report_date %></p>
                        <h1 class="hero-title">Uma leitura mais clara da sua noite.</h1>
                        <p class="lede">Olá, <strong><%= user_name %></strong>. <%= hero_copy %> Aqui vai o que realmente importa no céu de hoje, sem precisar abrir o app para entender tudo.</p>
                      </td>
                      <td width="104" align="right" class="moon-mark-wrap" style="vertical-align: top;">
                        <span class="moon-mark"><%= phase_icon %></span>
                      </td>
                    </tr>
                  </table>

                  <table role="presentation" width="100%" class="summary-card">
                    <tr>
                      <td>
                        <p class="summary-label">Leitura de hoje</p>
                        <p class="summary-value"><%= insight_title %></p>
                        <p class="summary-copy"><%= insight_copy %></p>
                      </td>
                    </tr>
                  </table>

                  <% if app_url.present? %>
                    <div class="hero-actions">
                      <a href="<%= app_url %>" class="button">Abrir Artemis</a>
                      <span class="button-secondary">Veja o painel completo quando quiser explorar mais detalhes.</span>
                    </div>
                  <% end %>
                </td>
              </tr>

              <tr>
                <td class="section">
                  <p class="section-title">O que importa agora</p>
                  <table role="presentation" width="100%" class="mobile-block">
                    <tr>
                      <td width="33.33%" style="padding-right: 8px; vertical-align: top;">
                        <table role="presentation" width="100%" class="metric-card">
                          <tr>
                            <td>
                              <p class="metric-label">Fase atual</p>
                              <p class="metric-value"><%= phase_name %></p>
                              <p class="metric-note">Seu panorama lunar principal para hoje.</p>
                            </td>
                          </tr>
                        </table>
                      </td>
                      <td class="mobile-gap" style="width: 0; font-size: 0; line-height: 0;">&nbsp;</td>
                      <td width="33.33%" style="padding-left: 4px; padding-right: 4px; vertical-align: top;">
                        <table role="presentation" width="100%" class="metric-card">
                          <tr>
                            <td>
                              <p class="metric-label">Signo lunar</p>
                              <p class="metric-value"><span class="pill pill-sign"><%= sign_name %></span></p>
                              <p class="metric-note">Um detalhe rápido para contextualizar o tom do dia.</p>
                            </td>
                          </tr>
                        </table>
                      </td>
                      <td class="mobile-gap" style="width: 0; font-size: 0; line-height: 0;">&nbsp;</td>
                      <td width="33.33%" style="padding-left: 8px; vertical-align: top;">
                        <table role="presentation" width="100%" class="metric-card">
                          <tr>
                            <td>
                              <p class="metric-label">Título da lua</p>
                              <p class="metric-value"><span class="pill <%= special_pill_class %>"><%= special_name %></span></p>
                              <p class="metric-note">Destaque especial do ciclo, quando existir.</p>
                            </td>
                          </tr>
                        </table>
                      </td>
                    </tr>
                  </table>
                </td>
              </tr>

              <tr>
                <td class="section">
                  <p class="section-title">Próximos marcos</p>
                  <table role="presentation" width="100%" class="mobile-block">
                    <tr>
                      <td width="50%" style="padding-right: 8px; vertical-align: top;">
                        <table role="presentation" width="100%" class="countdown-card">
                          <tr>
                            <td>
                              <p class="countdown-label">Lua cheia</p>
                              <p class="countdown-number"><%= full_days %></p>
                              <p class="countdown-unit"><%= full_days == 1 ? "dia restante" : "dias restantes" %></p>
                              <div class="progress-track">
                                <div class="progress-fill-gold" style="width: <%= full_progress %>%;"></div>
                              </div>
                            </td>
                          </tr>
                        </table>
                      </td>
                      <td class="mobile-gap" style="width: 0; font-size: 0; line-height: 0;">&nbsp;</td>
                      <td width="50%" style="padding-left: 8px; vertical-align: top;">
                        <table role="presentation" width="100%" class="countdown-card">
                          <tr>
                            <td>
                              <p class="countdown-label">Lua nova</p>
                              <p class="countdown-number"><%= new_days %></p>
                              <p class="countdown-unit"><%= new_days == 1 ? "dia restante" : "dias restantes" %></p>
                              <div class="progress-track">
                                <div class="progress-fill-blue" style="width: <%= new_progress %>%;"></div>
                              </div>
                            </td>
                          </tr>
                        </table>
                      </td>
                    </tr>
                  </table>
                </td>
              </tr>

              <tr>
                <td class="section">
                  <table role="presentation" width="100%" class="note-card">
                    <tr>
                      <td>
                        <p class="section-title" style="margin-bottom: 10px;">Resumo rápido</p>
                        <p class="note-copy">Seu próximo destaque lunar é <strong><%= next_event_copy.downcase %></strong>. Este boletim foi pensado para ser escaneável em poucos segundos: primeiro o contexto, depois o que muda em seguida.</p>
                      </td>
                    </tr>
                  </table>
                </td>
              </tr>

              <tr>
                <td class="footer">
                  <p class="footer-copy"><strong>Artemis</strong> • boletim diário enviado no seu horário de referência lunar.</p>
                  <p class="footer-copy">© <%= stockholm_time.year %> Artemis. Feito para transformar dados da lua em uma leitura rápida, bonita e útil.</p>
                </td>
              </tr>
            </table>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
