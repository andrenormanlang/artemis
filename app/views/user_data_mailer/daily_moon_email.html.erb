<% stockholm_time = Time.find_zone!("Europe/Stockholm").now %>
<% report_date = stockholm_time.strftime("%d/%m/%Y") %>
<% user_name = @user.name.presence || "explorador lunar" %>
<% phase_name = @moon_data.phase.presence || "Sem fase definida" %>
<% sign_name = @moon_data.sign.presence || "Sem signo definido" %>
<% special_name = @moon_data.special_moon.presence || "Nenhuma lua especial" %>
<% full_days = [(@moon_data.days_until_full_moon || 0).to_i, 0].max %>
<% new_days = [(@moon_data.days_until_new_moon || 0).to_i, 0].max %>
<% next_event_name, next_event_days = full_days <= new_days ? ["Lua cheia", full_days] : ["Lua nova", new_days] %>
<% next_event_copy = case next_event_days
                     when 0 then "#{next_event_name} hoje"
                     when 1 then "#{next_event_name} amanhã"
                     else        "#{next_event_days} dias para a #{next_event_name.downcase}"
                     end %>
<% hero_copy = case next_event_days
               when 0 then "A lua está em #{phase_name} e #{next_event_name.downcase} acontece hoje."
               when 1 then "A lua está em #{phase_name} e #{next_event_name.downcase} chega amanhã."
               else        "A lua está em #{phase_name} e faltam #{next_event_days} dias para a #{next_event_name.downcase}."
               end %>
<% insight_title, insight_copy = case phase_name.downcase
                                 when /nova/      then ["Momento de recomeço", "Fase boa para plantar intenções, simplificar a agenda e abrir espaço para um novo ciclo."]
                                 when /cheia/     then ["Energia no auge", "Período favorável para celebrar progresso, concluir pendências e observar o que ficou mais visível."]
                                 when /minguante/ then ["Hora de desacelerar", "A maré pede revisão, fechamento e menos ruído. Um bom momento para ajustar o ritmo."]
                                 when /crescente/ then ["Fase de construção", "Clima ideal para ganhar consistência, retomar planos e sustentar o que já começou."]
                                 else                  ["Leitura lunar do dia", "Hoje vale observar o céu com calma e usar o boletim como bússola para o ritmo do seu dia."]
                                 end %>
<% phase_icon = case phase_name.downcase
                when /nova/                                    then "🌑"
                when /quarto.*crescente/                       then "🌓"
                when /gibosa.*crescente|crescente.*gibosa/     then "🌔"
                when /crescente/                               then "🌒"
                when /cheia/                                   then "🌕"
                when /gibosa.*minguante|minguante.*gibosa/     then "🌖"
                when /quarto.*minguante/                       then "🌗"
                when /minguante/                               then "🌘"
                else                                                "🌙"
                end %>
<% has_special = special_name != "Nenhuma lua especial" %>
<% app_host = ENV["APP_HOST"].to_s.strip %>
<% app_url = if app_host.present?
               normalized_host = app_host.match?(/\Ahttps?:\/\//i) ? app_host : "https://#{app_host}"
               "#{normalized_host.chomp("/")}/moon"
             end %>

<link href="https://fonts.googleapis.com/css2?family=Bangers&family=Fraunces:ital,opsz,wght@0,9..144,100..900;1,9..144,100..900&display=swap" rel="stylesheet">

<div style="display:none;max-height:0;overflow:hidden;mso-hide:all;font-size:1px;line-height:1px;color:#07111f;">
  <%= "#{phase_icon} #{phase_name} · #{next_event_copy.capitalize}." %>
</div>

<table role="presentation" width="100%" style="background-color:#080e1a;margin:0;padding:0;">
  <tr>
    <td align="center" style="padding:32px 16px;">
      <table role="presentation" width="100%" style="max-width:520px;">
        <tr>
          <td>
            <table role="presentation" width="100%" style="background-color:#0d1526;border-radius:16px;overflow:hidden;border:1px solid #1e2d4a;">

              <%# ── Header bar ── %>
              <tr>
                <td style="padding:20px 28px 18px;border-bottom:1px solid #1a2640;">
                  <table role="presentation" width="100%">
                    <tr>
                      <td>
                        <span style="font-family:'DM Sans',sans-serif;font-size:11px;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;color:#4a6fa8;">Artemis</span>
                      </td>
                      <td align="right">
                        <span style="font-family:'DM Sans',sans-serif;font-size:11px;color:#304563;letter-spacing:0.04em;"><%= report_date %></span>
                      </td>
                    </tr>
                  </table>
                </td>
              </tr>

              <%# ── Hero ── %>
              <tr>
                <td style="padding:36px 28px 28px;">
                  <p style="font-family:'DM Sans',sans-serif;font-size:11px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:#3d5a80;margin:0 0 14px;">Fase atual</p>
                  <p style="font-family:'Fraunces',Georgia,serif;font-size:38px;font-weight:300;color:#e8dfc8;margin:0 0 6px;line-height:1.1;letter-spacing:-0.01em;">
                    <%= phase_icon %>&nbsp;<%= phase_name %>
                  </p>
                  <p style="font-family:'DM Sans',sans-serif;font-size:14px;font-weight:300;color:#6b85a6;margin:16px 0 0;line-height:1.6;">
                    Olá, <span style="color:#a8bdd4;font-weight:500;"><%= user_name %></span>. <%= hero_copy %>
                  </p>
                </td>
              </tr>

              <%# ── Insight card ── %>
              <tr>
                <td style="padding:0 28px 28px;">
                  <table role="presentation" width="100%" style="background-color:#0a1120;border-radius:10px;border:1px solid #1a2e4a;border-left:3px solid #c9a84c;">
                    <tr>
                      <td style="padding:18px 20px;">
                        <p style="font-family:'DM Sans',sans-serif;font-size:10px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:#c9a84c;margin:0 0 8px;">Hoje</p>
                        <p style="font-family:'Fraunces',Georgia,serif;font-size:19px;font-weight:400;color:#d4c5a0;margin:0 0 8px;line-height:1.3;"><%= insight_title %></p>
                        <p style="font-family:'DM Sans',sans-serif;font-size:13px;font-weight:300;color:#5a7396;margin:0;line-height:1.65;"><%= insight_copy %></p>
                      </td>
                    </tr>
                  </table>
                </td>
              </tr>

              <%# ── Data rows ── %>
              <tr>
                <td style="padding:0 28px 28px;">
                  <p style="font-family:'DM Sans',sans-serif;font-size:10px;font-weight:500;letter-spacing:0.14em;text-transform:uppercase;color:#3d5a80;margin:0 0 14px;">Contagem</p>
                  <table role="presentation" width="100%">
                    <tr>
                      <td style="font-family:'DM Sans',sans-serif;font-size:13px;color:#3d5a80;padding:9px 0;border-bottom:1px solid #131f33;font-weight:300;">Signo lunar</td>
                      <td align="right" style="font-family:'DM Sans',sans-serif;font-size:13px;color:#8aa4c2;padding:9px 0;border-bottom:1px solid #131f33;font-weight:400;"><%= sign_name %></td>
                    </tr>
                    <% if has_special %>
                    <tr>
                      <td style="font-family:'DM Sans',sans-serif;font-size:13px;color:#3d5a80;padding:9px 0;border-bottom:1px solid #131f33;font-weight:300;">Lua especial</td>
                      <td align="right" style="padding:9px 0;border-bottom:1px solid #131f33;">
                        <span style="font-family:'DM Sans',sans-serif;font-size:11px;font-weight:500;color:#c9a84c;background-color:#1d1608;border:1px solid #3d2e0a;border-radius:20px;padding:3px 10px;letter-spacing:0.03em;"><%= special_name %></span>
                      </td>
                    </tr>
                    <% end %>
                    <tr>
                      <td style="font-family:'DM Sans',sans-serif;font-size:13px;color:#3d5a80;padding:9px 0;border-bottom:1px solid #131f33;font-weight:300;">Lua cheia</td>
                      <td align="right" style="font-family:'DM Sans',sans-serif;font-size:13px;color:#8aa4c2;padding:9px 0;border-bottom:1px solid #131f33;font-weight:400;"><%= full_days %> <%= full_days == 1 ? "dia" : "dias" %></td>
                    </tr>
                    <tr>
                      <td style="font-family:'DM Sans',sans-serif;font-size:13px;color:#3d5a80;padding:9px 0;font-weight:300;">Lua nova</td>
                      <td align="right" style="font-family:'DM Sans',sans-serif;font-size:13px;color:#8aa4c2;padding:9px 0;font-weight:400;"><%= new_days %> <%= new_days == 1 ? "dia" : "dias" %></td>
                    </tr>
                  </table>
                </td>
              </tr>

              <%# ── CTA ── %>
              <% if app_url.present? %>
              <tr>
                <td style="padding:4px 28px 32px;">
                  <a href="<%= app_url %>" style="display:inline-block;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;letter-spacing:0.06em;color:#0d1526;background-color:#c9a84c;text-decoration:none;border-radius:8px;padding:12px 24px;">Abrir Artemis</a>
                </td>
              </tr>
              <% end %>

              <%# ── Footer ── %>
              <tr>
                <td align="center" style="padding:16px 28px;border-top:1px solid #111d30;">
                  <p style="font-family:'DM Sans',sans-serif;font-size:11px;color:#243448;margin:0;letter-spacing:0.04em;">© <%= stockholm_time.year %> Artemis</p>
                </td>
              </tr>

            </table>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>