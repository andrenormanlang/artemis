<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="color-scheme" content="dark light">
    <meta name="supported-color-schemes" content="dark light">
    <style>
      body {
        margin: 0;
        padding: 0;
        background-color: #07111f;
        color: #e7edf7;
        font-family: "Segoe UI", Arial, sans-serif;
      }

      table {
        border-collapse: collapse;
        border-spacing: 0;
      }

      td {
        padding: 0;
      }

      img {
        border: 0;
        display: block;
        line-height: 100%;
        max-width: 100%;
        outline: none;
        text-decoration: none;
      }

      a {
        color: #f6c871;
        text-decoration: none;
      }

      .email-body {
        width: 100%;
        background-color: #07111f;
        background-image:
          radial-gradient(circle at top left, rgba(107, 169, 215, 0.18), transparent 35%),
          radial-gradient(circle at top right, rgba(245, 188, 107, 0.14), transparent 28%);
      }

      .shell {
        width: 100%;
        max-width: 680px;
      }

      .card {
        background-color: #0d1a2d;
        border: 1px solid #1f3354;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(2, 6, 23, 0.4);
      }

      .hero {
        padding: 32px 32px 24px;
        background:
          radial-gradient(circle at top right, rgba(255, 221, 157, 0.18), transparent 30%),
          linear-gradient(135deg, #10203a 0%, #0d1a2d 48%, #172848 100%);
      }

      .moon-mark {
        display: inline-block;
        min-width: 82px;
        height: 82px;
        line-height: 82px;
        text-align: center;
        font-size: 44px;
        border-radius: 999px;
        background: linear-gradient(180deg, #183055 0%, #0f1e37 100%);
        border: 1px solid #375984;
      }

      .eyebrow {
        margin: 0 0 12px;
        color: #9ab5d2;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 1.6px;
        text-transform: uppercase;
      }

      .hero-title {
        margin: 0;
        color: #f6f8fc;
        font-family: Georgia, "Times New Roman", serif;
        font-size: 38px;
        line-height: 1.1;
        font-weight: 700;
      }

      .lede {
        margin: 14px 0 0;
        color: #d7e1ef;
        font-size: 16px;
        line-height: 1.7;
      }

      .summary-card {
        margin-top: 22px;
        background: rgba(8, 16, 31, 0.55);
        border: 1px solid rgba(122, 158, 198, 0.22);
        border-radius: 18px;
      }

      .summary-card td {
        padding: 18px 20px;
      }

      .summary-label {
        margin: 0 0 6px;
        color: #8eb0d4;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 1.4px;
        text-transform: uppercase;
      }

      .summary-value {
        margin: 0;
        color: #fff4dc;
        font-size: 24px;
        line-height: 1.2;
        font-weight: 700;
      }

      .summary-copy {
        margin: 8px 0 0;
        color: #d4deeb;
        font-size: 14px;
        line-height: 1.6;
      }

      .hero-actions {
        margin-top: 22px;
      }

      .button {
        display: inline-block;
        padding: 13px 20px;
        border-radius: 999px;
        background: linear-gradient(180deg, #f7cf82 0%, #e8aa42 100%);
        color: #172033;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
      }

      .button-secondary {
        display: inline-block;
        margin-left: 10px;
        color: #b8cae1;
        font-size: 13px;
      }

      .section {
        padding: 0 32px 28px;
      }

      .section-title {
        margin: 0 0 16px;
        color: #8eb0d4;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 1.6px;
        text-transform: uppercase;
      }

      .metric-card,
      .countdown-card,
      .note-card {
        background-color: #0a1527;
        border: 1px solid #203555;
        border-radius: 18px;
      }

      .metric-card td,
      .countdown-card td,
      .note-card td {
        padding: 18px;
      }

      .metric-label,
      .countdown-label {
        margin: 0 0 8px;
        color: #90a9c8;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1.2px;
      }

      .metric-value {
        margin: 0;
        color: #f4f7fb;
        font-size: 22px;
        line-height: 1.3;
        font-weight: 700;
      }

      .metric-note {
        margin: 8px 0 0;
        color: #97abc6;
        font-size: 13px;
        line-height: 1.5;
      }

      .pill {
        display: inline-block;
        padding: 7px 12px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.2px;
      }

      .pill-sign {
        background: #132540;
        border: 1px solid #345d8f;
        color: #a8d8ff;
      }

      .pill-special {
        background: #2d1d0f;
        border: 1px solid #ab7b33;
        color: #ffd58d;
      }

      .pill-neutral {
        background: #17263d;
        border: 1px solid #334b6d;
        color: #d6e2f2;
      }

      .countdown-number {
        margin: 0;
        color: #f7f9fc;
        font-family: Georgia, "Times New Roman", serif;
        font-size: 42px;
        line-height: 1;
        font-weight: 700;
      }

      .countdown-unit {
        margin: 8px 0 0;
        color: #c9d7e8;
        font-size: 14px;
        line-height: 1.5;
      }

      .progress-track {
        width: 100%;
        height: 8px;
        margin-top: 14px;
        border-radius: 999px;
        background-color: #16253d;
        overflow: hidden;
      }

      .progress-fill-gold {
        height: 8px;
        border-radius: 999px;
        background: linear-gradient(90deg, #f7cf82 0%, #e8aa42 100%);
      }

      .progress-fill-blue {
        height: 8px;
        border-radius: 999px;
        background: linear-gradient(90deg, #76bbff 0%, #4e89df 100%);
      }

      .note-copy {
        margin: 0;
        color: #cbd7e7;
        font-size: 14px;
        line-height: 1.7;
      }

      .footer {
        padding: 4px 32px 30px;
        text-align: center;
      }

      .footer-copy {
        margin: 0;
        color: #8095b2;
        font-size: 12px;
        line-height: 1.7;
      }

      .footer-copy strong {
        color: #c8d7ea;
      }

      @media only screen and (max-width: 620px) {
        .card {
          border-radius: 0 !important;
        }

        .hero,
        .section,
        .footer {
          padding-left: 20px !important;
          padding-right: 20px !important;
        }

        .hero-title {
          font-size: 31px !important;
        }

        .mobile-block,
        .mobile-block tbody,
        .mobile-block tr,
        .mobile-block td {
          display: block !important;
          width: 100% !important;
        }

        .mobile-gap {
          display: block !important;
          height: 12px !important;
          line-height: 12px !important;
        }

        .moon-mark-wrap {
          padding-top: 18px !important;
          text-align: left !important;
        }

        .button-secondary {
          display: block !important;
          margin: 12px 0 0 !important;
        }
      }
    </style>
  </head>

  <body>
    <%= yield %>
  </body>
</html>
