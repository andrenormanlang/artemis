<div style="min-height:100vh;background-color:#080e1a;display:flex;align-items:center;justify-content:center;padding:32px 16px;font-family:'DM Sans',-apple-system,Segoe UI,sans-serif;">
  <div style="width:100%;max-width:440px;background-color:#0d1526;border:1px solid #1e2d4a;border-radius:16px;padding:36px 32px;text-align:center;">
    <h1 style="font-family:Georgia,serif;font-size:24px;font-weight:300;color:#e8dfc8;margin:0 0 12px;"><%= @title %></h1>
    <p style="font-size:14px;font-weight:300;color:#6b85a6;margin:0 0 22px;line-height:1.6;"><%= @message %></p>
    <a href="<%= root_path %>" style="display:inline-block;font-size:13px;font-weight:500;color:#0d1526;background:#c9a84c;text-decoration:none;border-radius:8px;padding:11px 22px;">Ver a lua de hoje</a>
  </div>
</div>
